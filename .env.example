# Copy this file to .env and fill in your real key.
#
# IMPORTANT (Expo): client-side env vars MUST be prefixed with EXPO_PUBLIC_,
# otherwise Expo will NOT inline them into the app bundle and the value will be
# `undefined` at runtime in Expo Go. Access it only via dot notation:
#   process.env.EXPO_PUBLIC_ANTHROPIC_API_KEY
#
# Get a key at https://console.anthropic.com/
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (optional — scan-corpus telemetry). Leave unset and the app runs
# exactly as before: no writes, no waits. Setup: create a project at
# https://supabase.com, run supabase/schema.sql in the SQL editor, enable
# Authentication → Sign In/Up → "Anonymous sign-ins", then paste from
# Project Settings → API:
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
